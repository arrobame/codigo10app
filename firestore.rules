rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /records/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /games/{gameId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email == "delpuertomiguel7@gmail.com";
    }

    match /feedbackQuota/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /broadcasts/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.token.email == "delpuertomiguel7@gmail.com";
    }

    match /cantos/{id} {
      // Cualquiera ve los cantos aceptados; el owner ve también los pendientes.
      allow read: if resource.data.status == "accepted"
        || (request.auth != null
            && request.auth.token.email == "delpuertomiguel7@gmail.com");
      // Usuarios con sesión pueden sugerir, siempre como "pending".
      allow create: if request.auth != null
        && request.resource.data.status == "pending";
      // Solo el owner acepta / edita / rechaza.
      allow update, delete: if request.auth != null
        && request.auth.token.email == "delpuertomiguel7@gmail.com";
    }
  }
}
